<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>HYPAR INFINITY | Aadityaraj A P</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #6366f1; --bg: #030408; --sidebar: #090a10; --text: #f8fafc;
            --text-dim: #64748b; --card: rgba(30, 41, 59, 0.4); --border: rgba(99, 102, 241, 0.15);
            --founder: #f59e0b; --success: #10b981; --code-bg: #011627;
            --vh: 1vh; /* Mobile dynamic unit */
        }

        * { box-sizing: border-box; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); scrollbar-width: thin; }
        
        body { 
            font-family: 'Inter', sans-serif; 
            background: var(--bg); 
            color: var(--text); 
            margin: 0; 
            display: flex; 
            height: calc(var(--vh) * 100); 
            overflow: hidden; 
        }

        /* --- SIDEBAR --- */
        aside { width: 320px; background: var(--sidebar); border-right: 1px solid var(--border); display: flex; flex-direction: column; padding: 1.5rem; z-index: 100; }
        .brand { font-size: 1.8rem; font-weight: 900; color: var(--primary); letter-spacing: -1px; display: flex; align-items: center; gap: 10px; }
        .creator-tag { font-size: 0.6rem; color: var(--founder); border: 1px solid var(--founder); padding: 4px 10px; border-radius: 4px; display: inline-block; margin: 10px 0 20px 0; font-weight: 800; text-transform: uppercase; }

        /* --- THEME & MODES --- */
        .hud-label { font-size: 0.6rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1.5px; margin: 15px 0 8px 0; font-weight: bold; }
        .theme-grid { display: flex; gap: 12px; }
        .theme-dot { width: 28px; height: 28px; border-radius: 8px; cursor: pointer; border: 2px solid transparent; transform: rotate(45deg); }
        .theme-dot.active { border-color: white; transform: rotate(45deg) scale(1.1); box-shadow: 0 0 15px var(--primary); }

        .mode-selector { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 5px; }
        .mode-btn { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: var(--text-dim); padding: 10px 2px; font-size: 0.65rem; border-radius: 8px; cursor: pointer; font-weight: bold; }
        .mode-btn.active { background: var(--primary); color: white; box-shadow: 0 0 15px var(--primary); }

        /* --- VAULT --- */
        .vault-container { flex-grow: 1; background: rgba(0,0,0,0.4); border-radius: 16px; border: 1px solid var(--border); padding: 10px; overflow-y: auto; margin-top: 10px; }
        .vault-item { font-size: 0.7rem; padding: 12px; border-bottom: 1px solid var(--border); color: var(--text-dim); display: flex; justify-content: space-between; cursor: pointer; border-radius: 4px; margin-bottom: 4px; }
        .vault-item:hover { color: var(--primary); background: rgba(255,255,255,0.05); }

        /* --- MAIN FEED --- */
        main { flex-grow: 1; display: flex; flex-direction: column; position: relative; background-image: radial-gradient(var(--border) 1px, transparent 1px); background-size: 40px 40px; }
        .feed { flex-grow: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; padding-bottom: 120px; }

        /* --- ARTIFACT CARDS --- */
        .artifact { background: var(--card); border: 1px solid var(--border); border-radius: 20px; overflow: hidden; backdrop-filter: blur(12px); animation: emerge 0.4s ease-out; max-width: 800px; width: 100%; align-self: center; }
        @keyframes emerge { from { opacity: 0; transform: translateY(20px); } }
        .code-header { background: rgba(0,0,0,0.3); padding: 12px 18px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
        .code-window { background: var(--code-bg); padding: 20px; font-family: 'Fira Code', monospace; font-size: 0.8rem; color: #d6deeb; overflow-x: auto; white-space: pre-wrap; }

        /* --- PREVIEW PANEL --- */
        #preview-panel { position: fixed; right: -100%; top: 0; width: 100%; height: 100%; background: white; z-index: 2000; transition: 0.5s cubic-bezier(0.19, 1, 0.22, 1); border-left: 5px solid var(--primary); }
        #preview-panel.open { right: 0; }
        @media (min-width: 1000px) { #preview-panel { width: 600px; right: -600px; } }
        .close-preview { position: absolute; top: 20px; left: -50px; background: var(--primary); color: white; border: none; width: 50px; height: 50px; border-radius: 10px 0 0 10px; cursor: pointer; }

        /* --- UPLINK OVERLAY --- */
        #sync-overlay { position: fixed; inset: 0; background: rgba(3,4,8,0.98); z-index: 3000; display: none; align-items: center; justify-content: center; flex-direction: column; }
        .sync-bar { width: 200px; height: 2px; background: #111; margin-top: 20px; overflow: hidden; }
        .sync-progress { height: 100%; background: var(--primary); width: 0%; transition: 1.5s ease; }

        /* --- INPUT HUB --- */
        .input-area { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px; background: linear-gradient(transparent, var(--bg) 60%); z-index: 10; }
        .input-box { max-width: 800px; margin: 0 auto; background: rgba(15, 23, 42, 0.9); border: 1.5px solid var(--primary); border-radius: 50px; padding: 8px 8px 8px 25px; display: flex; align-items: center; gap: 10px; }
        input { flex: 1; background: transparent; border: none; color: white; font-size: 1rem; outline: none; }
        .btn-exec { background: var(--primary); color: white; border: none; padding: 12px 25px; border-radius: 50px; font-weight: 800; cursor: pointer; }

        @media (max-width: 900px) { aside { display: none; } }
    </style>
</head>
<body>

    <div id="sync-overlay">
        <i class="fa-solid fa-layer-group fa-spin fa-3x" style="color: var(--primary);"></i>
        <h3 style="letter-spacing: 4px; margin-top: 20px;">SYNCING HYPAR</h3>
        <div class="sync-bar"><div class="sync-progress" id="syncBar"></div></div>
    </div>

    <aside>
        <div class="brand"><i class="fa-solid fa-infinity"></i> HYPAR</div>
        <div class="creator-tag">MASTER ARCHITECT: AADITYARAJ A P</div>

        <div class="hud-label">Neural Palette</div>
        <div class="theme-grid">
            <div class="theme-dot active" style="background: #6366f1;" onclick="setTheme('#6366f1', this)"></div>
            <div class="theme-dot" style="background: #10b981;" onclick="setTheme('#10b981', this)"></div>
            <div class="theme-dot" style="background: #f59e0b;" onclick="setTheme('#f59e0b', this)"></div>
        </div>

        <div class="hud-label">Logic Engine</div>
        <div class="mode-selector">
            <button class="mode-btn active" onclick="setMode('ui', this)">UI/UX</button>
            <button class="mode-btn" onclick="setMode('py', this)">PY</button>
            <button class="mode-btn" onclick="setMode('jsx', this)">JSX</button>
        </div>

        <div class="hud-label">Sovereign Vault</div>
        <div class="vault-container" id="vault"></div>

        <button onclick="simulateSync()" style="background: var(--primary); border: none; color: white; padding: 12px; border-radius: 10px; font-weight: 800; cursor: pointer; margin-top: 20px; font-size: 0.7rem;">DEPLOY TO CLOUD</button>
    </aside>

    <main>
        <div class="feed" id="feed">
            <div id="empty-state" style="text-align: center; margin: auto; opacity: 0.15;">
                <i class="fa-solid fa-terminal fa-5x"></i>
                <h2 style="letter-spacing: 10px;">STANDBY</h2>
            </div>
        </div>

        <div class="input-area">
            <div class="input-box">
                <input type="text" id="userInput" placeholder="Initialize command..." onkeypress="if(event.key === 'Enter') execute()">
                <button class="btn-exec" onclick="execute()">RUN</button>
            </div>
        </div>
    </main>

    <div id="preview-panel">
        <button class="close-preview" onclick="togglePreview()"><i class="fa-solid fa-xmark"></i></button>
        <iframe id="sandbox" style="width:100%; height:100%; border:none;"></iframe>
    </div>

    <script>
        let currentMode = 'ui';
        let vault = JSON.parse(localStorage.getItem('hypar_vault')) || [];

        // --- MOBILE HEIGHT FIX ---
        const syncHeight = () => {
            document.documentElement.style.setProperty('--vh', `${window.innerHeight * 0.01}px`);
        };
        window.addEventListener('resize', syncHeight);
        syncHeight();

        function setTheme(color, el) {
            document.documentElement.style.setProperty('--primary', color);
            document.querySelectorAll('.theme-dot').forEach(d => d.classList.remove('active'));
            el.classList.add('active');
        }

        function setMode(m, btn) {
            currentMode = m;
            document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }

        function togglePreview() { document.getElementById('preview-panel').classList.toggle('open'); }

        function execute() {
            const input = document.getElementById('userInput');
            const val = input.value.trim();
            if(!val) return;
            document.getElementById('empty-state')?.remove();

            const id = Date.now();
            let code = "", preview = "";
            const color = getComputedStyle(document.documentElement).getPropertyValue('--primary');

            if(currentMode === 'ui') {
                code = `<div style="padding:40px; background:${color}; color:white; border-radius:25px; text-align:center; font-family:sans-serif; margin:20px;">\n  <h2>${val}</h2>\n  <small>HYPAR GENERATED UI</small>\n</div>`;
                preview = code;
            } else if(currentMode === 'py') {
                code = `# Python Simulation\ndef process():\n    return "${val.toUpperCase()}"\n\nprint(process())`;
                preview = `<body style="background:#000; color:#10b981; font-family:monospace; padding:30px;">> python3 engine.py<br>> Output: ${val}</body>`;
            } else {
                code = `const App = () => {\n  return <div>${val}</div>\n}`;
                preview = `<body style="background:#0f172a; color:#f8fafc; padding:30px; font-family:sans-serif;"><h3>JSX Component Render</h3><hr>${val}</body>`;
            }

            const artifact = { id, val, code, preview, mode: currentMode };
            renderArtifact(artifact);
            input.value = "";
        }

        function renderArtifact(art) {
            const div = document.createElement('div');
            div.className = 'artifact';
            div.innerHTML = `
                <div class="code-header">
                    <span style="font-size: 0.6rem; color: var(--primary); font-weight: 900;">[ ${art.mode.toUpperCase()} ] ID_${art.id.toString().slice(-4)}</span>
                    <div style="display:flex; gap:8px;">
                        <button class="mode-btn" onclick="runSandbox('${btoa(art.preview)}')">VIEW</button>
                        <button class="mode-btn" onclick="saveToVault('${btoa(JSON.stringify(art))}')"><i class="fa-solid fa-bookmark"></i></button>
                    </div>
                </div>
                <div class="code-window">${art.code.replace(/</g, '&lt;')}</div>
            `;
            document.getElementById('feed').prepend(div);
            document.getElementById('feed').scrollTo({ top: 0, behavior: 'smooth' });
        }

        function runSandbox(base64) {
            document.getElementById('sandbox').srcdoc = atob(base64);
            togglePreview();
        }

        function saveToVault(data64) {
            const item = JSON.parse(atob(data64));
            vault.push(item);
            localStorage.setItem('hypar_vault', JSON.stringify(vault));
            refreshVault();
        }

        function refreshVault() {
            const v = document.getElementById('vault');
            if (vault.length === 0) {
                v.innerHTML = '<div style="text-align:center; padding:20px; font-size:0.6rem; opacity:0.3;">VAULT EMPTY</div>';
                return;
            }
            v.innerHTML = vault.map((i, index) => `
                <div class="vault-item" onclick="renderArtifact(vault[${index}])">
                    <span>${i.val.substring(0,10)}..</span>
                    <span style="color:var(--primary); font-weight:bold;">${i.mode.toUpperCase()}</span>
                </div>
            `).join('');
        }

        function simulateSync() {
            const overlay = document.getElementById('sync-overlay');
            const bar = document.getElementById('syncBar');
            overlay.style.display = 'flex';
            setTimeout(() => bar.style.width = '100%', 100);
            setTimeout(() => {
                overlay.style.display = 'none';
                bar.style.width = '0%';
            }, 1800);
        }

        function clearVault() { vault = []; localStorage.removeItem('hypar_vault'); refreshVault(); }
        
        refreshVault();
    </script>
</body>
  </html>
